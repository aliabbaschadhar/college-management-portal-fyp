generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  admin     Admin?
  faculty   Faculty?
  student   Student?
}

model Student {
  id             String        @id @default(uuid())
  userId         String        @unique
  rollNo         String        @unique
  phone          String?
  department     String
  semester       Int           @default(1)
  enrollmentDate DateTime      @default(now())
  avatar         String?
  attendances    Attendance[]
  enrollments    Enrollment[]
  fees           Fee[]
  feedbacks      Feedback[]
  grades         Grade[]
  quizAttempts   QuizAttempt[]
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Faculty {
  id             String   @id @default(uuid())
  userId         String   @unique
  phone          String?
  department     String
  specialization String
  joinDate       DateTime @default(now())
  avatar         String?
  teaches        Course[]
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Admin {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id              String       @id @default(uuid())
  courseCode      String       @unique
  courseName      String
  creditHours     Int
  department      String
  semester        Int          @default(1)
  assignedFaculty String?
  attendances     Attendance[]
  faculty         Faculty?     @relation(fields: [assignedFaculty], references: [id])
  enrollments     Enrollment[]
  grades          Grade[]
  quizzes         Quiz[]
  timetables      Timetable[]
}

model Enrollment {
  id        String  @id @default(uuid())
  studentId String
  courseId  String
  semester  Int
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
}

model Attendance {
  id        String           @id @default(uuid())
  studentId String
  courseId  String
  date      DateTime
  status    AttendanceStatus
  markedBy  String
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId, date])
}

model Fee {
  id        String    @id @default(uuid())
  studentId String
  type      String
  amount    Float
  status    FeeStatus @default(Unpaid)
  dueDate   DateTime
  semester  Int
  paidDate  DateTime?
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Announcement {
  id       String               @id @default(uuid())
  title    String
  content  String
  author   String
  date     DateTime             @default(now())
  audience AnnouncementAudience
  priority Priority             @default(Medium)
}

model Feedback {
  id        String       @id @default(uuid())
  studentId String
  type      FeedbackType
  targetId  String
  rating    Int
  comment   String
  date      DateTime     @default(now())
  student   Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Timetable {
  id        String @id @default(uuid())
  courseId  String
  room      String
  day       String
  startTime String
  endTime   String
  course    Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Quiz {
  id         String        @id @default(uuid())
  title      String
  courseId   String
  createdBy  String
  duration   Int
  totalMarks Int
  status     String
  dueDate    DateTime
  questions  Question[]
  course     Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attempts   QuizAttempt[]
}

model Question {
  id            String   @id @default(uuid())
  text          String
  options       String[]
  correctOption Int
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id          String   @id @default(uuid())
  quizId      String
  studentId   String
  score       Int
  totalMarks  Int
  submittedAt DateTime @default(now())
  answers     Int[]
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Grade {
  id              String  @id @default(uuid())
  studentId       String
  courseId        String
  quizMarks       Float
  assignmentMarks Float
  midMarks        Float
  finalMarks      Float
  total           Float
  gpa             Float
  locked          Boolean @default(false)
  course          Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student         Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Admission {
  id                  String   @id @default(uuid())
  studentName         String
  email               String
  phone               String
  appliedDepartment   String
  applicationDate     DateTime @default(now())
  status              String   @default("Pending")
  fatherName          String
  cnic                String
  previousInstitution String
  marksObtained       Float
  totalMarks          Float
}

enum Role {
  STUDENT
  FACULTY
  ADMIN
}

enum AttendanceStatus {
  Present
  Absent
  Late
}

enum FeeStatus {
  Paid
  Unpaid
  Overdue
}

enum AnnouncementAudience {
  Students
  Faculty
  All
}

enum Priority {
  High
  Medium
  Low
}

enum FeedbackType {
  Faculty
  Course
}
